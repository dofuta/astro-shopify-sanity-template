# サイト設定
BASE_DOMAIN=https://example.com
AUTHOR="My Shop"
THEME_COLOR="#E2E2E1"
SITE_TITLE="My Shop"

# Shopify Storefront API
# Shopify管理画面 > Apps > Headless アプリ からトークンを発行
# 「非公開アクセストークン」を使用する（サーバー側専用・絶対に公開しないこと）
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-private-storefront-token
SHOPIFY_API_VERSION=2026-01

# Shopify Analytics（任意）
# Live View 等を有効化する場合のみ true にする。本番にプレビュー用スクリプトを出さない場合は false/未設定にする。
PUBLIC_SHOPIFY_ANALYTICS_ENABLED=false
# Storefront API Proxy がサーバー側で注入する「公開アクセストークン」。
# クライアントJSには埋め込まない。
SHOPIFY_PUBLIC_STOREFRONT_ACCESS_TOKEN=your-public-storefront-token

# Shopify Admin API（任意・開発時のみ）
# `npm run gen:metafields` でメタフィールド定義の config を自動生成する場合にのみ使用する。
# カスタムアプリの Admin API アクセストークン（`read_products` スコープ）を設定する。
# ※ビルド/本番では不要。Netlify 等には登録しなくてよい。
# SHOPIFY_ADMIN_API_ACCESS_TOKEN=your-admin-api-access-token

# Sanity
# sanity.io/manage でプロジェクトを作成して取得（案件ごとに新規プロジェクトを作成する）
# ※ Sanity 公式の規約により、Studio 関連の変数は SANITY_STUDIO_ 接頭辞で統一する
# （sanity.config.ts / sanity.cli.ts と、埋め込みStudioのブラウザバンドルの両方から読める値になる）
SANITY_STUDIO_PROJECT_ID=your-project-id
SANITY_STUDIO_DATASET=production
# Live Preview（Presentation Tool からの Visual Editing）を有効にする場合のみ true にする。
# true にすると Sanity 連携ページ（/news 以下）が SSR になる。本番では false のままにする。
SANITY_VISUAL_EDITING_ENABLED=false
# Viewer権限のAPIトークン（sanity.io/manage > API > Tokens）。Live Preview 時のみ必要。
# SANITY_API_READ_TOKEN=your-read-token
# Presentation Tool がフロントエンドを開くURL
SANITY_STUDIO_PREVIEW_URL=http://localhost:4321
