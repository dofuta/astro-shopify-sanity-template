---
import type { Product } from '~/lib/types';
import ProductForm from './ProductForm';

interface Props {
  product: Product;
}

const { product } = Astro.props;

const variants = product.variants.edges.map((e) => e.node);
---

<section class="product-detail">
  <div class="product-detail__media">
    {
      product.featuredImage ? (
        <img
          src={product.featuredImage.url}
          alt={product.featuredImage.altText ?? product.title}
          class="product-detail__main-image"
          width="800"
          height="800"
          decoding="async"
        />
      ) : (
        <div class="product-detail__image-placeholder" aria-hidden="true" />
      )
    }
  </div>

  <div class="product-detail__info">
    <h1 class="product-detail__title">{product.title}</h1>

    <ProductForm
      client:load
      productId={product.id}
      productTitle={product.title}
      variants={variants}
      options={product.options}
      initialPrice={product.priceRange.minVariantPrice}
    />

    {
      product.descriptionHtml && (
        <div class="product-detail__description" set:html={product.descriptionHtml} />
      )
    }

    {
      product.metafields.length > 0 && (
        <dl class="product-detail__metafields">
          {product.metafields.map((mf) => (
            <div class="product-detail__metafield">
              <dt>{mf.label}</dt>
              <dd>{mf.value}</dd>
            </div>
          ))}
        </dl>
      )
    }
  </div>
</section>

<style lang="scss">
  .product-detail {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;

    @media (min-width: 768px) {
      grid-template-columns: 1fr 1fr;
      gap: 48px;
    }

    &__media {
      aspect-ratio: 1 / 1;
      overflow: hidden;
      background-color: #f5f5f5;
    }

    &__main-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    &__image-placeholder {
      width: 100%;
      height: 100%;
      background-color: #e0e0e0;
    }

    &__info {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    &__title {
      margin: 0;
      font-size: 1.5rem;
      font-weight: 600;
      line-height: 1.3;
    }

    &__description {
      margin-top: 8px;
      font-size: 0.9rem;
      line-height: 1.8;
      color: #444;

      :global(p) {
        margin: 0 0 12px;
      }
    }

    &__metafields {
      margin: 8px 0 0;
      display: flex;
      flex-direction: column;
      gap: 12px;
      border-top: 1px solid #eee;
      padding-top: 16px;
    }

    &__metafield {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2px;
      font-size: 0.85rem;

      @media (min-width: 480px) {
        grid-template-columns: 120px 1fr;
        gap: 12px;
      }

      dt {
        margin: 0;
        font-weight: 600;
        color: #555;
      }

      dd {
        margin: 0;
        color: #444;
        line-height: 1.7;
        white-space: pre-wrap;
      }
    }
  }
</style>
